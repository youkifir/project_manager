@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<project_manager.Models.ViewModels.UserRolesViewModel>

@{
    ViewData["Title"] = "User Management";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-people"></i> User Management</h1>
        <div>
            <a asp-action="ListRoles" class="btn btn-outline-secondary me-2">
                <i class="bi bi-shield-lock"></i> View Roles
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">User Details</th>
                        <th>Current Roles</th>
                        <th class="text-center" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-primary">@item.User.UserName</div>
                                <div class="small text-muted">@item.User.Email</div>
                            </td>
                            <td>
                                @if (item.Roles.Any())
                                {
                                    @foreach (var role in item.Roles)
                                    {
                                        <span class="badge bg-info text-dark me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small italic">No roles assigned</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="EditUserRoles" asp-route-userId="@item.User.Id"
                                   class="btn btn-sm btn-primary px-3">
                                    <i class="bi bi-pencil-square"></i> Edit Roles
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning mt-3">
            No users found in the system.
        </div>
    }
</div>