@model IEnumerable<project_manager.Models.Task>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "_Layout";
    ViewData["Title"] = "Задачи проекта";
    var projectId = ViewBag.ProjectId;
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-3">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index">Проекты</a></li>
                <li class="breadcrumb-item active">@ViewBag.ProjectName</li>
            </ol>
        </nav>
        <h1>Задачи проекта</h1>
    </div>
    <a asp-action="Create" asp-route-projectId="@projectId" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Добавить задачу
    </a>
</div>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Заголовок</th>
            <th>Исполнитель</th> @**@
            <th>Срок выполнения</th> @**@
            <th>Статус</th>
            <th style="width: 200px;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var task in Model)
        {
            var isOverdue = task.DueDate < DateTime.Now && !task.IsCompleted;
            <tr class="@(isOverdue ? "table-danger" : "")">
                <td>
                    <span class="fw-bold">@task.Title</span>
                </td>
                <td>
                    <i class="bi bi-person"></i>
                    @(task.AssignedUser?.UserName ?? "Не назначен")
                </td>
                <td class="@(isOverdue ? "text-danger fw-bold" : "")">
                    @task.DueDate.ToString("dd.MM.yyyy HH:mm")
                </td>
                <td>
                    @if (task.IsCompleted)
                    {
                        <span class="badge bg-success">Выполнена</span>
                    }
                    else
                    {
                        <span class="badge bg-primary">В работе</span>
                    }
                </td>
                <td>
                    <div class="btn-group">
                        <a asp-action="Details" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-info">Детали</a>
                        <a asp-action="Update" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-primary">Изменить</a>
                        <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-danger">Удалить</a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">В этом проекте пока нет задач. Создайте первую!</div>
}