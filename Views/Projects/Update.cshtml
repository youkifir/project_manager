@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model project_manager.Models.Entities.Project

@{
    Layout = "_Layout";
    ViewData["Title"] = "Update Project";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h3 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Project</h3>
            </div>
            <div class="card-body p-4">
                <form asp-action="Update" asp-controller="Projects" method="post">
                    <input type="hidden" asp-for="ProjectId" />

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold">Project Name</label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Enter name..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5" placeholder="What is this project about?"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-top pt-4">
                        <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-primary btn-lg px-5">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            Project created on: @Model.CreatedAt.ToString("f")
        </div>
    </div>
</div>