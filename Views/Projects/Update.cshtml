@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model project_manager.Models.Project

@{
    Layout = "_Layout";
    ViewData["Title"] = "Update";
}

<h1 class="mb-4">Update Project</h1>

<div class="alert alert-info shadow-sm">
    <h4 class="alert-heading">Current Data:</h4>
    <hr>
    <p class="mb-1"><strong>Id:</strong> @Model.ProjectId</p>
    <p class="mb-1"><strong>Name:</strong> @Model.Name</p>
    <p class="mb-1"><strong>Description:</strong> @Model.Description</p>
    <p class="mb-1"><strong>Owner Id:</strong> @Model.OwnerId</p>
    <p class="mb-0"><strong>Created At:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
</div>

<hr class="my-4" />

<form asp-action="Update" asp-controller="Projects" method="post">
    <input type="hidden" asp-for="ProjectId" />

    <div class="mb-3">
        <label asp-for="ProjectId" class="form-label">Project Id: </label>
        <input asp-for="ProjectId" class="form-control bg-light" readonly />
    </div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name: </label>
        <input asp-for="Name" class="form-control" placeholder="Input project name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description: </label>
        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Input project description"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mt-4">
        <input class="btn btn-primary" type="submit" value="Save Changes" />
        <a asp-action="Index" asp-controller="Projects" class="btn btn-secondary">Cancel</a>
    </div>
</form>