@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model project_manager.Models.Project

@{
    Layout = "_Layout";
    ViewData["Title"] = "Delete Project";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white text-center py-3">
                <h3 class="mb-0"><i class="bi bi-exclamation-octagon"></i> Delete Project</h3>
            </div>
            <div class="card-body py-4 text-center">
                <p class="lead">Are you sure you want to permanently delete this project?</p>

                <div class="bg-light p-3 rounded border mb-4">
                    <h4 class="text-dark">@Model.Name</h4>
                    <p class="text-muted mb-0">@Model.Description</p>
                </div>

                <div class="alert alert-warning border-0 small">
                    <i class="bi bi-info-circle"></i> All associated tasks for this project will also be deleted.
                </div>
            </div>
            <div class="card-footer bg-white py-3">
                <form asp-action="Delete" asp-controller="Projects" method="post" class="d-flex justify-content-center gap-3">
                    <input type="hidden" name="id" value="@Model.ProjectId" />

                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>