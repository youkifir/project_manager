@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model project_manager.Models.Project

@{
    Layout = "_Layout";
    ViewData["Title"] = "Delete";
}

<h1 class="text-danger">Delete Project</h1>
<p class="lead">Are you sure you want to delete this project?</p>

<div class="alert alert-warning shadow-sm mt-4">
    <h4 class="alert-heading">Project to be deleted:</h4>
    <hr>
    <p class="mb-1"><strong>Id:</strong> @Model.ProjectId</p>
    <p class="mb-1"><strong>Name:</strong> @Model.Name</p>
    <p class="mb-1"><strong>Description:</strong> @Model.Description</p>
    <p class="mb-1"><strong>Owner Id:</strong> @Model.OwnerId</p>
    <p class="mb-0"><strong>Created At:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
</div>

<form asp-action="Delete" asp-controller="Projects" method="post" class="mt-4">
    <input type="hidden" name="id" value="@Model.ProjectId" />

    <input class="btn btn-danger" type="submit" value="Confirm Delete" />
    <a asp-action="Index" asp-controller="Projects" class="btn btn-secondary">Cancel</a>
</form>
