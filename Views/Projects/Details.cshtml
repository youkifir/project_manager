@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model project_manager.Models.Project

@{
    ViewData["Title"] = "Project Details";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
            <h2 class="mb-0">@Model.Name</h2>
            <span class="badge bg-info align-self-center">Created: @Model.CreatedAt.ToString("d")</span>
        </div>
        <div class="card-body">
            <h5 class="text-muted">Description</h5>
            <p class="lead">@Model.Description</p>

            <hr />

            <div class="d-flex gap-2">
                <a asp-controller="Tasks" asp-action="Index" asp-route-projectId="@Model.ProjectId" class="btn btn-primary lg">
                    <i class="bi bi-list-check"></i> Manage Tasks
                </a>
            </div>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Projects</a>
            <div>
                <a asp-action="Update" asp-route-id="@Model.ProjectId" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.ProjectId" class="btn btn-danger">Delete</a>
            </div>
        </div>
    </div>
</div>